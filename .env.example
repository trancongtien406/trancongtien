# Website API token used by trusted automation. Set the same value in the Next.js app process.
CONTENT_AUTOMATION_TOKEN=

# Website process. Use trancongtien.com -> 127.0.0.1:3342.
WEB_PORT=3342
PORT=3342
SITE_ORIGIN=https://trancongtien.com

# Public MCP access token used by ChatGPT/custom connector. Use a different long random value.
MCP_ACCESS_TOKEN=
MCP_PORT=3343
# MCP process. Use mcp.trancongtien.com -> 127.0.0.1:3343.

# Optional comma-separated allowlist for upload_cover image_url input.
# Prefer image_base64 when possible.
MCP_ALLOWED_IMAGE_HOSTS=
